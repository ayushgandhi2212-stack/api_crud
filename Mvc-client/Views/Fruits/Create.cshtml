@model Mvc_client.Models.Fruits_api

@{
    ViewData["Title"] = "Add Fruit";
}

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <!-- Card UI -->
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center">
                    <h4>🍏 Add New Fruit</h4>
                </div>

                <div class="card-body">

                    <form asp-action="Create" method="post">

                        <!-- Validation Summary -->
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Fruit Name -->
                        <div class="mb-3">
                            <label asp-for="fruit_Name" class="form-label"></label>
                            <input asp-for="fruit_Name" class="form-control" placeholder="Enter fruit name" />
                            <span asp-validation-for="fruit_Name" class="text-danger"></span>
                        </div>

                        <!-- Quantity -->
                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" placeholder="Enter quantity" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                ← Back
                            </a>

                            <button type="submit" class="btn btn-success">
                                Save
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}